---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, siteContent, type Locale } from '../../data/site';

export function getStaticPaths() {
	return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;

if (!locales.includes(lang)) {
	throw new Error(`Unsupported locale: ${lang}`);
}

const content = siteContent[lang];
const alternates = locales.map((locale) => ({
	lang: locale,
	href: `/${locale}/`,
}));
const emailAddress = content.contact.email;
const mailtoHref = `mailto:${emailAddress}`;

const processCardImages = [
	'/images/corbetti/getapro-house-frame-01.jpg',
	'/images/corbetti/facade-project.jpg',
	'/images/corbetti/montaz-03.jpg',
	'/images/corbetti/finished-corridor.jpg',
];

const clientCardImages = [
	'/images/corbetti/getapro-house-11.jpg',
	'/images/corbetti/getapro-windows-12.jpg',
	'/images/corbetti/getapro-facade-b-03.jpg',
];

const initialReviews = (content.reviews?.items ?? []).map((item, index) => ({
	id: `static-${index}`,
	name: item.author,
	message: item.quote,
	rating: 5,
}));
---

<BaseLayout
	lang={lang}
	title={content.metaTitle}
	description={content.metaDescription}
	alternates={alternates}
	canonicalPath={`/${lang}/`}
>
	<div class="page-shell" id="top">
		<header class="site-header">
			<div class="container header-inner">
				<a class="brand" href={`/${lang}/`}>
					<span class="brand-mark" aria-hidden="true">
						<img
							src="/images/corbetti/branding/corbetti-mark-c-web-v3.png"
							alt=""
							class="brand-mark-image"
							loading="eager"
							decoding="async"
						/>
					</span>
					<span class="brand-copy">
						<strong>CORBETTI OÜ</strong>
						<small>{content.hero.eyebrow}</small>
					</span>
				</a>

				<nav class="main-nav" aria-label="Primary">
					<a href="#top">{content.nav.home}</a>
					<a href="#services">{content.nav.services}</a>
					<a href="#process">{content.nav.process}</a>
					<a href="#clients">{content.nav.clients}</a>
					<a href="#portfolio">{content.nav.portfolio}</a>
					<a href="#faq">{content.nav.faq}</a>
					<a href="#contact">{content.nav.contact}</a>
				</nav>

				<a class="header-phone" href="tel:+37256333338">+372 5633 3338</a>

				<div class="language-switcher" aria-label="Languages">
					{
						locales.map((locale) => (
							<a class:list={['lang-pill', { active: locale === lang }]} href={`/${locale}/`}>
								{siteContent[locale].langLabel}
							</a>
						))
					}
				</div>

			</div>
		</header>

		<main>
			<section class="hero-section">
				<div class="container">
					<div class="hero-shell reveal">
						<img src="/images/corbetti/getapro-house-cover.jpg" alt="Corbetti OÜ project" class="hero-bg-image" />
						<div class="hero-overlay"></div>
						<div class="hero-copy hero-copy-centered">
							<p class="section-kicker section-kicker-light">{content.hero.eyebrow}</p>
							<h1>{content.hero.title}</h1>
							<p class="hero-text">{content.hero.description}</p>
							<div class="hero-actions hero-actions-centered">
								<a class="button button-primary" href="#contact">{content.hero.primaryCta}</a>
								<a class="button button-secondary button-secondary-dark" href="#portfolio">{content.hero.secondaryCta}</a>
							</div>
						</div>

						<div class="hero-experience-stamp" aria-label={content.hero.stamp}>
							<span>15+</span>
							<strong>{content.hero.stamp}</strong>
						</div>

						<div class="hero-stats hero-stats-overlay">
							{
								content.hero.stats.map((stat) => (
									<div class="stat-card stat-card-dark">
										<strong>{stat.value}</strong>
										<span>{stat.label}</span>
									</div>
								))
							}
						</div>

					</div>
				</div>
			</section>

			<section class="intro-section">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.intro.kicker}</p>
					</div>
				</div>
				<div class="container intro-panel">
					<div class="reveal">
						<p class="section-text intro-body">{content.intro.body}</p>
						<div class="badge-row">
							{
								content.intro.badges.map((badge) => (
									<span class="info-badge">{badge}</span>
								))
							}
						</div>
					</div>

					<div class="intro-metrics">
						{
							content.hero.stats.map((stat) => (
								<div class="intro-metric reveal">
									<strong>{stat.value}</strong>
									<span>{stat.label}</span>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="services-section" id="services">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.services.kicker}</p>
					</div>

					<div class="service-catalog">
						{
							content.services.cards.map((card, index) => (
								<article class="service-category reveal" style={`--delay:${index * 80}ms`}>
									<div class="service-category-heading">
										<h3>{card.title}</h3>
									</div>
									<p class="service-category-text">{card.text}</p>
									<ul class="service-category-list">
										{card.items.map((item) => <li>{item}</li>)}
									</ul>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="process-section" id="process">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.process.kicker}</p>
					</div>
					<div class="service-catalog process-catalog">
						{
							content.process.steps.map((step, index) => (
								<article
									class="service-category process-category media-card reveal"
									style={`--delay:${index * 70}ms; --card-image:url('${processCardImages[index % processCardImages.length]}'); --float-duration:${15 + index * 1.5}s; --float-shift:${index % 2 === 0 ? '12px' : '-12px'}; --float-delay:${index * -1.8}s;`}
								>
									<div class="service-category-heading">
										<h3>{step.title}</h3>
									</div>
									<p class="service-category-text">{step.text}</p>
								</article>
							))
						}
					</div>
					{
						content.process.certificates && (
							<div class="process-certificates reveal">
								<div class="process-certificates-head">
									<p class="section-kicker process-certificates-kicker">{content.process.certificates.title}</p>
								</div>
								<div class="process-certificates-grid">
									{
										content.process.certificates.items.map((certificate) => (
											<article class="process-certificate-card">
												<strong>{certificate.name}</strong>
												<span>{certificate.number}</span>
											</article>
										))
									}
								</div>
							</div>
						)
					}
				</div>
			</section>

			<section class="clients-section" id="clients">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.clients.kicker}</p>
					</div>
					<div class="service-catalog client-catalog">
						{
							content.clients.cards.map((card, index) => (
								<article
									class="service-category client-category media-card reveal"
									style={`--delay:${index * 70}ms; --card-image:url('${clientCardImages[index % clientCardImages.length]}'); --float-duration:${16 + index * 1.8}s; --float-shift:${index % 2 === 0 ? '10px' : '-10px'}; --float-delay:${index * -1.5}s;`}
								>
									<div class="service-category-heading">
										<h3>{card.title}</h3>
									</div>
									<p class="service-category-text">{card.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			{
				content.reviews && (
					<section class="reviews-section">
						<div class="container">
							<div class="catalog-heading reveal">
								<p class="section-kicker">{content.reviews.kicker}</p>
							</div>
							<div class="reviews-shell reveal">
								<div class="reviews-summary">
									<div class="reviews-headline">
										<div class="reviews-rating-block">
											<strong class="reviews-rating-value" data-reviews-rating-value>{content.reviews.stats[0]?.value ?? '5.0 / 5'}</strong>
											<span class="reviews-rating-label" data-reviews-rating-label>{content.reviews.stats[0]?.label}</span>
											<div class="reviews-rating-inline">
												<span class="review-stars reviews-summary-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
												<button type="button" class="reviews-count-button" data-reviews-toggle aria-expanded="false">
													({content.reviews.items.length})
												</button>
											</div>
										</div>
									</div>
									<div class="reviews-stats">
										<div class="reviews-stat-card reviews-stat-card-accent">
											<strong>{content.reviews.stats[1]?.value ?? '100%'}</strong>
											<span>{content.reviews.stats[1]?.label}</span>
										</div>
									</div>
									<button
										type="button"
										class="button button-primary reviews-action"
										data-review-open
									>
										{content.reviews.actionLabel}
									</button>
								</div>

								<div class="reviews-grid" data-reviews-panel data-initial-reviews={JSON.stringify(initialReviews)}>
									{
										content.reviews.items.map((item, index) => (
											<article class="review-card" style={`--delay:${index * 90}ms`}>
												<div class="review-card-topline">
													<div>
														<h3>{item.author}</h3>
													</div>
													<span class="review-stars" aria-label="5 out of 5 stars">★★★★★</span>
												</div>
												<p class="review-quote">{item.quote}</p>
											</article>
										))
									}
								</div>
							</div>
						</div>
					</section>
				)
			}

			<section class="portfolio-section" id="portfolio">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.portfolio.kicker}</p>
					</div>

					<div class="portfolio-showcase">
						{
							content.portfolio.items.map((item, itemIndex) => (
								<article class="portfolio-project reveal" style={`--delay:${itemIndex * 110}ms`}>
									{(() => {
										const galleryGroup = `project-${itemIndex}`;
										const firstImage = item.images[0];
										const coverImage = item.coverImage ?? item.images[item.images.length - 1] ?? item.images[0];
										return (
											<>
												<button
													type="button"
													class="portfolio-folder"
													data-gallery-open-group={galleryGroup}
													data-gallery-open-index="0"
													aria-label={item.title}
												>
													<div class="portfolio-folder-copy">
														<div class="portfolio-folder-topline">
															<span class="portfolio-project-index">0{itemIndex + 1}</span>
															<span class="portfolio-folder-count">{item.images.length}</span>
														</div>
														<h3>{item.title}</h3>
														{item.text && <p>{item.text}</p>}
													</div>
													<div class="portfolio-folder-preview">
														{
															coverImage && (
																<img
																	src={coverImage}
																	alt={item.title}
																	loading="lazy"
																	class="portfolio-folder-cover"
																/>
															)
														}
														{
															firstImage && (
																<img
																	src={firstImage}
																	alt={item.title}
																	loading="lazy"
																	class="portfolio-folder-start"
																/>
															)
														}
													</div>
												</button>
												<div class="portfolio-gallery-hidden" aria-hidden="true">
													{
														item.images.map((image, imageIndex) => (
															<button
																type="button"
																class="portfolio-gallery-hidden-tile"
																tabindex="-1"
																data-gallery-group={galleryGroup}
																data-gallery-image={image}
																data-gallery-title={item.title}
																data-gallery-caption={`${item.title} ${imageIndex + 1}`}
																aria-hidden="true"
															/>
														))
													}
												</div>
											</>
										);
									})()}
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="faq-section" id="faq">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.faq.kicker}</p>
					</div>
					{
						(content.faq.title || content.faq.body) && (
							<div class="faq-intro reveal">
								{content.faq.title && <h2>{content.faq.title}</h2>}
								{content.faq.body && <p class="section-text">{content.faq.body}</p>}
							</div>
						)
					}
					<div class="faq-grid">
						{
							content.faq.categories.map((category, categoryIndex) => (
								<article class="faq-category reveal" style={`--delay:${categoryIndex * 70}ms`}>
									<div class="faq-category-heading">
										<h3>{category.title}</h3>
									</div>
									<div class="faq-items">
										{
											category.items.map((item) => (
												<details class="faq-item">
													<summary>{item.question}</summary>
													<p>{item.answer}</p>
												</details>
											))
										}
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="contact-section" id="contact">
				<div class="container">
					<div class="catalog-heading reveal">
						<p class="section-kicker">{content.contact.kicker}</p>
					</div>
				</div>
				<div class="container contact-shell">
					<div class="contact-copy reveal">
						<p class="contact-lead">{content.contact.title}</p>
						<p class="section-text">{content.contact.body}</p>
						<p class="contact-email">
							<span>{content.contact.emailLabel}</span>
							<a href={mailtoHref}>{content.contact.email}</a>
						</p>
						<p class="contact-email">
							<span>{content.contact.phoneLabel}</span>
							<a href={content.contact.primaryHref}>{content.contact.phone}</a>
						</p>
					</div>
					<div class="contact-cards">
						<form class="contact-form reveal" data-inquiry-form>
							<h3>{content.contact.form.title}</h3>
							<label class="form-field">
								<span>{content.contact.form.nameLabel}</span>
								<input name="name" type="text" autocomplete="name" required />
							</label>
							<label class="form-field">
								<span>{content.contact.form.phoneLabel}</span>
								<input name="phone" type="tel" autocomplete="tel" required />
							</label>
							<label class="form-field">
								<span>{content.contact.form.locationLabel}</span>
								<input name="location" type="text" autocomplete="street-address" />
							</label>
							<label class="form-field">
								<span>{content.contact.form.workTypeLabel}</span>
								<input name="workType" type="text" />
							</label>
							<label class="form-field">
								<span>{content.contact.form.messageLabel}</span>
								<textarea name="message" rows="4" required></textarea>
							</label>
							<button
								class="button button-primary form-submit"
								type="submit"
								data-submit-label={content.contact.form.submitLabel}
								data-submitting-label={content.contact.form.submittingLabel}
							>
								{content.contact.form.submitLabel}
							</button>
							<p
								class="form-note"
								data-form-note
								data-default-note={content.contact.form.telegramNotice}
								data-success-message={content.contact.form.successMessage}
								data-error-message={content.contact.form.errorMessage}
							>
								{content.contact.form.telegramNotice}
							</p>
						</form>
						<dialog class="inquiry-dialog" data-inquiry-dialog>
							<div class="inquiry-dialog-inner">
								<h3>{content.contact.form.successTitle}</h3>
								<p data-inquiry-dialog-message>{content.contact.form.successMessage}</p>
								<button type="button" class="button button-primary" data-inquiry-dialog-close>
									OK
								</button>
							</div>
						</dialog>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<div>
					<strong>{content.footer.company}</strong>
					<p>{content.footer.rights}</p>
				</div>
				<a href="#top">{content.nav.contact}</a>
			</div>
		</footer>

		<dialog class="gallery-dialog" data-gallery-dialog>
			<button type="button" class="gallery-dialog-close" aria-label="Close gallery" data-gallery-close>
				&#215;
			</button>
			<div class="gallery-dialog-inner">
				<div class="gallery-dialog-stage">
					<button type="button" class="gallery-dialog-nav gallery-dialog-nav-prev" aria-label="Previous photo" data-gallery-prev>
						&#8249;
					</button>
					<img src="" alt="" class="gallery-dialog-image" data-gallery-preview />
					<button type="button" class="gallery-dialog-nav gallery-dialog-nav-next" aria-label="Next photo" data-gallery-next>
						&#8250;
					</button>
				</div>
				<div class="gallery-dialog-copy">
					<strong data-gallery-preview-title></strong>
					<span data-gallery-preview-caption></span>
				</div>
			</div>
		</dialog>

		{
			content.reviews && (
				<dialog class="review-dialog" data-review-dialog>
					<button type="button" class="gallery-dialog-close" aria-label="Close review form" data-review-close>
						&#215;
					</button>
					<form class="review-form" data-review-form>
						<h3>{content.reviews.form.title}</h3>
						<label class="form-field">
							<span>{content.reviews.form.nameLabel}</span>
							<input name="name" type="text" autocomplete="name" required />
						</label>
						<fieldset class="rating-field">
							<legend>{content.reviews.form.ratingLabel}</legend>
							<div class="rating-stars" role="radiogroup" aria-label={content.reviews.form.ratingLabel}>
								{[1, 2, 3, 4, 5].map((value) => (
									<label class="rating-star">
										<input type="radio" name="rating" value={value} required />
										<span aria-hidden="true">★</span>
									</label>
								))}
							</div>
						</fieldset>
						<label class="form-field">
							<span>{content.reviews.form.messageLabel}</span>
							<textarea name="message" rows="3" required></textarea>
						</label>
						<button
							type="submit"
							class="button button-primary form-submit"
							data-submit-label={content.reviews.form.submitLabel}
							data-submitting-label={content.reviews.form.submittingLabel}
						>
							{content.reviews.form.submitLabel}
						</button>
						<p
							class="form-note"
							data-review-note
							data-success-message={content.reviews.form.successMessage}
							data-error-message={content.reviews.form.errorMessage}
						></p>
					</form>
					<div class="review-success" data-review-success hidden>
						<div class="review-success-mark" aria-hidden="true">★</div>
						<h3>{content.reviews.form.successTitle}</h3>
						<p>{content.reviews.form.successBody}</p>
						<button type="button" class="button button-primary" data-review-success-close>
							OK
						</button>
					</div>
				</dialog>
			)
		}
	</div>

	<script is:inline>
		const galleryDialog = document.querySelector('[data-gallery-dialog]');
		const galleryPreview = document.querySelector('[data-gallery-preview]');
		const galleryPreviewTitle = document.querySelector('[data-gallery-preview-title]');
		const galleryPreviewCaption = document.querySelector('[data-gallery-preview-caption]');
		const galleryClose = document.querySelector('[data-gallery-close]');
		const galleryPrev = document.querySelector('[data-gallery-prev]');
		const galleryNext = document.querySelector('[data-gallery-next]');
		const inquiryForm = document.querySelector('[data-inquiry-form]');
		const reviewDialog = document.querySelector('[data-review-dialog]');
		const reviewOpen = document.querySelector('[data-review-open]');
		const reviewClose = document.querySelector('[data-review-close]');
		const reviewForm = document.querySelector('[data-review-form]');
		const reviewSuccess = document.querySelector('[data-review-success]');
		const reviewSuccessClose = document.querySelector('[data-review-success-close]');
		const reviewsToggle = document.querySelector('[data-reviews-toggle]');
		const reviewsPanel = document.querySelector('[data-reviews-panel]');
		const initialReviews = JSON.parse(reviewsPanel?.getAttribute('data-initial-reviews') ?? '[]');
		const reviewsRatingValue = document.querySelector('[data-reviews-rating-value]');
		const reviewsRatingLabel = document.querySelector('[data-reviews-rating-label]');
		const inquiryDialog = document.querySelector('[data-inquiry-dialog]');
		const inquiryDialogClose = document.querySelector('[data-inquiry-dialog-close]');

		const escapeHtml = (value) =>
			String(value ?? '')
				.replaceAll('&', '&amp;')
				.replaceAll('<', '&lt;')
				.replaceAll('>', '&gt;')
				.replaceAll('"', '&quot;')
				.replaceAll("'", '&#39;');

		const renderStars = (rating) => {
			const normalizedRating = Math.max(1, Math.min(5, Number(rating) || 5));
			return '\u2605'.repeat(normalizedRating) + '\u2606'.repeat(5 - normalizedRating);
		};

		const renderReviews = (reviews) => {
			if (!reviewsPanel) {
				return;
			}

			reviewsPanel.innerHTML = reviews
				.map(
					(item, index) => `
						<article class="review-card" style="--delay:${index * 90}ms">
							<div class="review-card-topline">
								<div>
									<h3>${escapeHtml(item.name)}</h3>
								</div>
								<span class="review-stars" aria-label="${Number(item.rating) || 5} out of 5 stars">${renderStars(item.rating)}</span>
							</div>
							<p class="review-quote">${escapeHtml(item.message)}</p>
						</article>
					`,
				)
				.join('');

			if (reviewsToggle) {
				reviewsToggle.textContent = `(${reviews.length})`;
			}

			if (reviewsRatingValue && reviewsRatingLabel) {
				const averageRating =
					reviews.length > 0
						? reviews.reduce((total, item) => total + (Number(item.rating) || 5), 0) / reviews.length
						: 5;

				reviewsRatingValue.textContent = `${averageRating.toFixed(1)} / 5`;
				reviewsRatingLabel.textContent = reviews.length === 1 ? '1 review' : `${reviews.length} reviews`;
			}
		};

		renderReviews(initialReviews);

		if (galleryDialog && galleryPreview && galleryPreviewTitle && galleryPreviewCaption) {
			const galleryTiles = Array.from(document.querySelectorAll('[data-gallery-image]'));
			const galleryOpeners = Array.from(document.querySelectorAll('[data-gallery-open-group]'));
			let activeGalleryIndex = -1;
			let activeGalleryTiles = [];

			const renderGalleryItem = (index) => {
				const normalizedIndex = (index + activeGalleryTiles.length) % activeGalleryTiles.length;
				const activeTile = activeGalleryTiles[normalizedIndex];

				if (!activeTile) {
					return;
				}

				activeGalleryIndex = normalizedIndex;
				galleryPreview.setAttribute('src', activeTile.getAttribute('data-gallery-image') ?? '');
				galleryPreview.setAttribute('alt', activeTile.getAttribute('data-gallery-caption') ?? '');
				galleryPreviewTitle.textContent = activeTile.getAttribute('data-gallery-title') ?? '';
				galleryPreviewCaption.textContent = activeTile.getAttribute('data-gallery-caption') ?? '';
			};

			const stepGallery = (direction) => {
				if (!activeGalleryTiles.length) {
					return;
				}

				const nextIndex = activeGalleryIndex >= 0 ? activeGalleryIndex + direction : 0;
				renderGalleryItem(nextIndex);
			};

			galleryTiles.forEach((tile, index) => {
				tile.addEventListener('click', () => {
					const group = tile.getAttribute('data-gallery-group') ?? '';
					activeGalleryTiles = galleryTiles.filter(
						(candidate) => (candidate.getAttribute('data-gallery-group') ?? '') === group,
					);
					const nextIndex = activeGalleryTiles.indexOf(tile);
					renderGalleryItem(nextIndex >= 0 ? nextIndex : index);
					galleryDialog.showModal();
				});
			});

			galleryOpeners.forEach((opener) => {
				opener.addEventListener('click', () => {
					const group = opener.getAttribute('data-gallery-open-group') ?? '';
					const startIndex = Number(opener.getAttribute('data-gallery-open-index') ?? '0');
					activeGalleryTiles = galleryTiles.filter(
						(candidate) => (candidate.getAttribute('data-gallery-group') ?? '') === group,
					);

					if (!activeGalleryTiles.length) {
						return;
					}

					renderGalleryItem(Number.isNaN(startIndex) ? 0 : startIndex);
					galleryDialog.showModal();
				});
			});

			galleryClose?.addEventListener('click', () => galleryDialog.close());
			galleryPrev?.addEventListener('click', () => stepGallery(-1));
			galleryNext?.addEventListener('click', () => stepGallery(1));

			galleryDialog.addEventListener('click', (event) => {
				if (event.target === galleryDialog) {
					galleryDialog.close();
				}
			});

			galleryDialog.addEventListener('keydown', (event) => {
				if (event.key === 'ArrowLeft') {
					event.preventDefault();
					stepGallery(-1);
				}

				if (event.key === 'ArrowRight') {
					event.preventDefault();
					stepGallery(1);
				}
			});
		}

		if (inquiryForm) {
			const submitButton = inquiryForm.querySelector('.form-submit');
			const formNote = inquiryForm.querySelector('[data-form-note]');

			inquiryForm.addEventListener('submit', async (event) => {
				event.preventDefault();

				const formData = new FormData(inquiryForm);
				const name = String(formData.get('name') ?? '').trim();
				const phone = String(formData.get('phone') ?? '').trim();
				const location = String(formData.get('location') ?? '').trim();
				const workType = String(formData.get('workType') ?? '').trim();
				const message = String(formData.get('message') ?? '').trim();

				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = true;
					submitButton.textContent = submitButton.dataset.submittingLabel ?? 'Sending...';
				}

				if (formNote instanceof HTMLElement) {
					formNote.textContent = formNote.dataset.defaultNote ?? '';
					formNote.dataset.state = 'idle';
				}

				try {
					const response = await fetch('/api/telegram-inquiry', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
						},
						body: JSON.stringify({
							name,
							phone,
							location,
							workType,
							message,
							pageUrl: window.location.href,
							locale: document.documentElement.lang || 'ru',
						}),
					});

					if (!response.ok) {
						throw new Error(`Request failed with status ${response.status}`);
					}

					inquiryForm.reset();

					if (formNote instanceof HTMLElement) {
						formNote.textContent = formNote.dataset.successMessage ?? '';
						formNote.dataset.state = 'success';
					}

					if (inquiryDialog instanceof HTMLDialogElement) {
						inquiryDialog.showModal();
					}
				} catch (error) {
					console.error(error);

					if (formNote instanceof HTMLElement) {
						formNote.textContent = formNote.dataset.errorMessage ?? '';
						formNote.dataset.state = 'error';
					}
				} finally {
					if (submitButton instanceof HTMLButtonElement) {
						submitButton.disabled = false;
						submitButton.textContent = submitButton.dataset.submitLabel ?? 'Submit';
					}
				}

				return;
				const lines = [
					'Новая заявка с сайта CORBETTI OÜ',
					`Имя: ${name}`,
					`Телефон: ${phone}`,
					location ? `Адрес объекта: ${location}` : '',
					workType ? `Тип работ: ${workType}` : '',
					`Описание: ${message}`,
				].filter(Boolean);
				const telegramUrl = `${telegramShareBase}?text=${encodeURIComponent(lines.join('\n'))}`;

				window.open(telegramUrl, '_blank', 'noopener,noreferrer');
			});
		}

		inquiryDialogClose?.addEventListener('click', () => inquiryDialog?.close());
		inquiryDialog?.addEventListener('click', (event) => {
			if (event.target === inquiryDialog) {
				inquiryDialog.close();
			}
		});

		if (reviewDialog && reviewOpen) {
			reviewOpen.addEventListener('click', () => {
				reviewForm?.removeAttribute('hidden');
				reviewSuccess?.setAttribute('hidden', '');
				reviewDialog.showModal();
			});
			reviewClose?.addEventListener('click', () => reviewDialog.close());
			reviewSuccessClose?.addEventListener('click', () => reviewDialog.close());
			reviewDialog.addEventListener('click', (event) => {
				if (event.target === reviewDialog) {
					reviewDialog.close();
				}
			});
		}

		if (reviewsToggle && reviewsPanel) {
			reviewsToggle.addEventListener('click', () => {
				const isExpanded = reviewsToggle.getAttribute('aria-expanded') === 'true';
				reviewsToggle.setAttribute('aria-expanded', String(!isExpanded));

				if (isExpanded) {
					reviewsPanel.classList.remove('is-open');
				} else {
					reviewsPanel.classList.add('is-open');
				}
			});
		}

		if (reviewForm) {
			const submitButton = reviewForm.querySelector('.form-submit');
			const formNote = reviewForm.querySelector('[data-review-note]');
			const ratingInputs = Array.from(reviewForm.querySelectorAll('input[name="rating"]'));
			const updateRatingVisuals = () => {
				const selectedValue = Number(
					ratingInputs.find((input) => input instanceof HTMLInputElement && input.checked)?.value ?? '0',
				);

				ratingInputs.forEach((input) => {
					if (!(input instanceof HTMLInputElement)) {
						return;
					}

					input.parentElement?.classList.toggle('is-active', Number(input.value) <= selectedValue);
				});
			};

			ratingInputs.forEach((input) => input.addEventListener('change', updateRatingVisuals));
			updateRatingVisuals();

			reviewForm.addEventListener('submit', async (event) => {
				event.preventDefault();

				const formData = new FormData(reviewForm);
				const name = String(formData.get('name') ?? '').trim();
				const rating = String(formData.get('rating') ?? '').trim();
				const message = String(formData.get('message') ?? '').trim();

				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = true;
					submitButton.textContent = submitButton.dataset.submittingLabel ?? 'Sending...';
				}

				if (formNote instanceof HTMLElement) {
					formNote.textContent = '';
					formNote.dataset.state = 'idle';
				}

				try {
					const response = await fetch('/api/reviews', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
						},
						body: JSON.stringify({
							name,
							message: `${'★'.repeat(Number(rating) || 5)}\n${message}`,
							locale: document.documentElement.lang || 'ru',
						}),
					});

					if (!response.ok) {
						throw new Error(`Request failed with status ${response.status}`);
					}

					reviewForm.reset();
					updateRatingVisuals();

					const reviewsResponse = await fetch('/api/reviews', {
						headers: {
							Accept: 'application/json',
						},
					});

					if (reviewsResponse.ok) {
						const reviewsPayload = await reviewsResponse.json();

						if (Array.isArray(reviewsPayload.reviews)) {
							renderReviews(reviewsPayload.reviews);
						}
					}

					if (formNote instanceof HTMLElement) {
						formNote.textContent = formNote.dataset.successMessage ?? '';
						formNote.dataset.state = 'success';
					}

					reviewForm.setAttribute('hidden', '');
					reviewSuccess?.removeAttribute('hidden');
				} catch (error) {
					console.error(error);

					if (formNote instanceof HTMLElement) {
						formNote.textContent = formNote.dataset.errorMessage ?? '';
						formNote.dataset.state = 'error';
					}
				} finally {
					if (submitButton instanceof HTMLButtonElement) {
						submitButton.disabled = false;
						submitButton.textContent = submitButton.dataset.submitLabel ?? 'Submit';
					}
				}
			});
		}

		fetch('/api/reviews', {
			headers: {
				Accept: 'application/json',
			},
		})
			.then((response) => (response.ok ? response.json() : null))
			.then((payload) => {
				if (payload && Array.isArray(payload.reviews) && payload.reviews.length > 0) {
					renderReviews(payload.reviews);
				}
			})
			.catch((error) => {
				console.error(error);
			});
	</script>
</BaseLayout>

